# Required for the backend to start.
ADMIN_API_KEY=change-this-admin-key

# Local demo defaults.
ALLOW_MOCK_RESPONSES=true
DATABASE_URL=sqlite:////app/first_aid_chatbot.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080
VITE_API_BASE_URL=http://localhost:8000

# Optional OpenAI-backed path.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_REASONING_EFFORT=low
